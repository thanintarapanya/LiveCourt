// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: reservations
// Document ID: auto-generated
// Fields:
//   - courtId: string (required) - ID of the court
//   - customerName: string (required) - Name of the customer
//   - lineUserId: string (optional) - LINE User ID
//   - startTime: string (required) - ISO date string
//   - endTime: string (required) - ISO date string
//   - status: string (required) - ['pending', 'confirmed', 'cancelled']
//   - createdAt: timestamp (required) - Creation time
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "info@embeddedlinuxgroup.com" && request.auth.token.email_verified == true));
    }

    function isValidReservation(data) {
      return data.courtId is string &&
             data.customerName is string && data.customerName.size() < 100 &&
             data.status in ['pending', 'confirmed', 'cancelled'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /reservations/{reservationId} {
      // Allow the server-side API to create (if using client SDK on server, we might need a specific check or allow public create for this prototype)
      // For this prototype, we allow public create to support the LINE Mini App API if it's called without user auth context
      allow create: if isValidReservation(request.resource.data);
      
      // Only admins or authenticated staff can read/update/delete
      allow read, update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }
  }
}
